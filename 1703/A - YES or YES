#include<bits/stdc++.h>
using namespace std;
 
int main() {
  
    int n;
    string s;
    cin >> n;
    string yes = "yes";
    
    for(int i = 0; i < n; i++){
        cin >> s;
        bool y = 1;
        for(int j = 0; j < 3; j++){
            if(tolower(s[j]) != yes[j]){
                y = 0;
                break;
            }
        }
        
        if (y) cout << "YES" << endl;
        else cout << "NO" << endl;
    }
}