#include<bits/stdc++.h>
#include<numeric>
using namespace std;
 
int solve(){
    
    int n, k, a;
    bool b = 0;
    
    cin >> n >> k;
    
    for(int i = 0; i < n; i++){
        cin >> a;
        
        if(a == k) b = 1;
    }
    
    if(b == 0) cout << "NO" << endl;
    else cout << "YES" << endl;
 
    return 0; 
}
 
 
int main() {
  
    int t;
    cin >> t;
    
    for(int i = 0; i < t; i++){
        solve();
    }
    
    
    return 0;
}